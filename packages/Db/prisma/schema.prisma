datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  fullName      String
  phone         String
  role          String         @default("PATIENT") // "DOCTOR" | "PATIENT" | "STAFF" | "ADMIN"
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  doctorProfile DoctorProfile?
  patientProfile PatientProfile?
  auditLogs     AuditLog[]
}

model DoctorProfile {
  id             String        @id @default(uuid())
  userId         String        @unique
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialty      String
  licenseNumber  String        @unique // CNOM number
  cabinetAddress String
  city           String
  appointments   Appointment[]
}

model PatientProfile {
  id             String          @id @default(uuid())
  userId         String          @unique
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  cin            String          @unique // Carte d'Identité Nationale
  birthDate      DateTime
  gender         String          // "M" or "F"
  address        String?
  appointments   Appointment[]
  medicalRecords MedicalRecord[]
  consentLogs    ConsentLog[]
  auditLogs      AuditLog[]      @relation("PatientAudited")
}

model Appointment {
  id             String            @id @default(uuid())
  patientId      String
  patient        PatientProfile    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId       String
  doctor         DoctorProfile     @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  dateTime       DateTime
  type           String            @default("PHYSICAL") // "PHYSICAL" | "TELECONSULTATION"
  status         String            @default("PENDING")  // "PENDING" | "CONFIRMED" | "CANCELLED" | "COMPLETED"
  whatsappOptIn  Boolean           @default(false)
  telecomRoomUrl String?
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model MedicalRecord {
  id                       String         @id @default(uuid())
  patientId                String
  patient                  PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId                 String
  // Encrypted fields at application level (ALE) to comply with Law 09-08 / CNDP
  symptomsEncrypted        String
  diagnosesEncrypted       String
  prescriptionsEncrypted   String
  additionalNotesEncrypted String?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
}

model ConsentLog {
  id                 String         @id @default(uuid())
  patientId          String
  patient            PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  consentType        String         // "TELECONSULTATION" | "WHATSAPP_REMINDERS" | "DATA_TREATMENT"
  isGranted          Boolean        @default(false)
  timestamp          DateTime       @default(now())
  ipAddress          String
  signatureImageUri  String?
}

model AuditLog {
  id            String         @id @default(uuid())
  actorId       String
  actor         User           @relation(fields: [actorId], references: [id])
  action        String         // "READ_RECORD" | "WRITE_RECORD" | "DELETE_RECORD" | "EXPORT_DATA"
  patientId     String
  patient       PatientProfile @relation("PatientAudited", fields: [patientId], references: [id], onDelete: Cascade)
  timestamp     DateTime       @default(now())
  ipAddress     String
  userAgent     String
  justification String?
}
